---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact — Van Inzicht naar Impact"
  description="Neem contact op met Lysette Hakvoort voor advies over leren, ontwikkeling en kwaliteitsverbetering in uw zorgorganisatie."
>

  <!-- Page hero -->
  <section class="bg-stone-50 border-b border-stone-100 py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl">
        <SectionHeading
          label="Contact"
          title="Maak kennis"
          subtitle="Heeft u een vraagstuk op het gebied van leren, ontwikkeling of kwaliteitsverbetering? Of bent u gewoon benieuwd wat ik voor uw organisatie kan betekenen? Ik hoor graag van u."
        />
      </div>
    </div>
  </section>

  <!-- Contact grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <div class="bg-white rounded-2xl border border-stone-100 p-8 shadow-sm">
            <h2 class="font-serif text-xl text-olive-dark mb-6">Stuur een bericht</h2>
            <ContactForm />
          </div>
        </div>

        <!-- Contact info -->
        <div class="lg:col-span-2 flex flex-col gap-8">
          <div class="reveal reveal-delay-1">
            <h2 class="font-serif text-xl text-olive-dark mb-5">Direct contact</h2>
            <div class="flex flex-col gap-5">
              <a
                href="mailto:vaninzichtnaarimpact@outlook.com"
                class="group flex items-start gap-4 bg-white rounded-xl p-4 border border-stone-100 hover:border-olive/30 hover:shadow-sm transition-all duration-200"
              >
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 group-hover:bg-olive/20 transition-colors">
                  <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-copper uppercase tracking-wider mb-0.5">E-mail</div>
                  <div class="text-sm text-ink">vaninzichtnaarimpact@outlook.com</div>
                </div>
              </a>

              <a
                href="tel:+31623922983"
                class="group flex items-start gap-4 bg-white rounded-xl p-4 border border-stone-100 hover:border-olive/30 hover:shadow-sm transition-all duration-200"
              >
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 group-hover:bg-olive/20 transition-colors">
                  <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-copper uppercase tracking-wider mb-0.5">Telefoon</div>
                  <div class="text-sm text-ink">06-23922983</div>
                </div>
              </a>

              <a
                href="https://www.linkedin.com/in/dr-lysette-hakvoort-92666b71/"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-4 bg-white rounded-xl p-4 border border-stone-100 hover:border-olive/30 hover:shadow-sm transition-all duration-200"
              >
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 group-hover:bg-olive/20 transition-colors">
                  <svg class="w-5 h-5 text-olive" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs font-semibold text-copper uppercase tracking-wider mb-0.5">LinkedIn</div>
                  <div class="text-sm text-ink">Dr. Lysette Hakvoort</div>
                </div>
              </a>
            </div>
          </div>

          <!-- Reactietijd blok -->
          <div class="reveal reveal-delay-2 bg-olive/5 rounded-2xl p-6 border border-olive/10">
            <div class="flex items-start gap-3">
              <div class="text-2xl flex-shrink-0" aria-hidden="true">⏱️</div>
              <div>
                <div class="font-semibold text-olive-dark text-sm mb-1">Reactietijd</div>
                <p class="text-ink-muted text-sm leading-relaxed">
                  Ik reageer altijd binnen twee werkdagen. Een kennismaking is vrijblijvend.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
