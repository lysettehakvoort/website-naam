---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';

const expertise = [
  'Verpleegkundig leren en werkplekleren',
  'Ontwerp en evaluatie van scholingsprogramma\'s',
  'Leercultuur en leerklimaat in zorgorganisaties',
  'Kwaliteitsverbetering en professionele ontwikkeling',
  'Implementatie van verandering in complexe zorgomgevingen',
  'Projectleiding bij leer- en ontwikkelingsvraagstukken',
];
---

<BaseLayout
  title="Over Dr. Lysette Hakvoort — Van Inzicht naar Impact"
  description="Academicus en praktijkadviseur. Lysette Hakvoort combineert wetenschappelijk inzicht met jarenlange ervaring in verpleegkundig leren."
>

  <!-- Page hero -->
  <section class="bg-stone-50 border-b border-stone-100 py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl">
        <SectionHeading
          label="Over mij"
          title="Dr. Lysette Hakvoort"
          subtitle="Adviseur professionele ontwikkeling van verpleegkundigen"
        />
      </div>
    </div>
  </section>

  <!-- Introductie -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">

        <!-- Foto + contactinfo -->
        <div class="lg:col-span-2 reveal">
          <div class="rounded-3xl overflow-hidden border border-stone-100 relative max-w-sm mx-auto lg:mx-0">
            <img
              src="/foto-profiellysette.jpeg"
              alt="Dr. Lysette Hakvoort — Adviseur professionele ontwikkeling van verpleegkundigen"
              class="w-full h-auto object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-gradient-to-r from-olive via-olive-light to-copper"></div>
          </div>

          <!-- Promotiefoto -->
          <div class="mt-6 rounded-3xl overflow-hidden border border-stone-100 max-w-sm mx-auto lg:mx-0">
            <img
              src="/foto-promotielysette.jpeg"
              alt="Dr. Lysette Hakvoort"
              class="w-full h-auto object-cover"
            />
          </div>

          <!-- Contactinfo card -->
          <div class="mt-6 bg-white border border-stone-100 rounded-2xl p-5 max-w-sm mx-auto lg:mx-0">
            <div class="font-serif font-semibold text-olive-dark mb-1">Dr. Lysette Hakvoort</div>
            <div class="text-xs text-copper font-medium uppercase tracking-wider mb-4">Adviseur professionele ontwikkeling van verpleegkundigen</div>
            <div class="flex flex-col gap-2.5 text-sm text-ink-muted">
              <a href="mailto:vaninzichtnaarimpact@outlook.com" class="flex items-center gap-2 hover:text-olive transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                vaninzichtnaarimpact@outlook.com
              </a>
              <a href="tel:+31623922983" class="flex items-center gap-2 hover:text-olive transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                06-23922983
              </a>
              <a href="https://www.linkedin.com/in/drlysettehakvoort-92666b71" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-olive transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn profiel
              </a>
            </div>
          </div>
        </div>

        <!-- Tekst -->
        <div class="lg:col-span-3 flex flex-col gap-10">

          <!-- Over mij -->
          <div class="reveal">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Over mij</h2>
            <div class="space-y-4 text-ink-muted leading-relaxed">
              <p>
                Verpleegkundigen zijn de grootste beroepsgroep in de zorg, staan het dichtst bij de patiënt en hebben dagelijks directe invloed op de kwaliteit van zorg. Die positie biedt enorm potentieel — mits professionele ontwikkeling duurzaam is verankerd in de praktijk.
              </p>
              <p>
                Dat is waar ik voor sta. Ik maak zichtbaar wat de professionele ontwikkeling van verpleegkundigen belemmert en help organisaties dit om te zetten naar een aanpak die wél werkt. Onderbouwd, praktisch en afgestemd op de dagelijkse praktijk.
              </p>
              <p>
                De versterking van professionele zeggenschap van verpleegkundigen is de rode draad in mijn carrière. Ik geloof dat verpleegkundigen niet alleen de uitvoerders zijn van zorg, maar ook de experts die mede richting geven aan hoe die zorg zich ontwikkelt.
              </p>
            </div>
          </div>

          <!-- Werkervaring -->
          <div class="reveal reveal-delay-1">
            <h2 class="font-serif text-subheading text-olive-dark mb-6">Werkervaring</h2>
            <div class="flex flex-col gap-6">

              <!-- Verpleegkundige -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink text-sm mb-1">Verpleegkundige</div>
                  <p class="text-ink-muted text-sm leading-relaxed">
                    Jarenlange praktijkervaring als verpleegkundige heeft mij een diepgaand begrip gegeven van hoe het er in de praktijk aan toe gaat — de zorg- en werkprocessen, dynamische werkomstandigheden, de organisatiecultuur én de onverwoestbare drive om de best mogelijke patiëntenzorg te leveren. Die ervaringen vormen het fundament van alles wat ik doe.
                  </p>
                </div>
              </div>

              <!-- Academisch -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink text-sm mb-1">Academische achtergrond</div>
                  <p class="text-ink-muted text-sm leading-relaxed">
                    Ik ben afgestudeerd als Master Verplegingswetenschappen en vervolgens gepromoveerd op het proefschrift <a href="https://researchinformation.umcutrecht.nl/en/publications/mind-the-gap-bridging-the-knowledge-to-practice-gap-in-nursing/" target="_blank" rel="noopener noreferrer" class="text-olive font-medium hover:text-olive-dark underline underline-offset-2 transition-colors"><em>Mind the Gap: Bridging the Knowledge to Practice Gap in Nursing</em></a> — een onderzoek naar de professionele ontwikkeling van verpleegkundigen en het dichten van de kloof tussen kennis en praktijk. Wetenschap en praktijk zijn voor mij onlosmakelijk verbonden.
                  </p>
                </div>
              </div>

              <!-- Senior adviseur -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink text-sm mb-1">Senior adviseur verpleegkundig onderzoek</div>
                  <p class="text-ink-muted text-sm leading-relaxed">
                    Als senior adviseur heb ik jarenlang verpleegkundig onderzoek aangejaagd en gefaciliteerd. Ik verbind wetenschap met de werkvloer en help organisaties om onderzoeksmatig denken te verankeren in de dagelijkse zorgpraktijk — zodat inzichten niet blijven liggen, maar leiden tot aantoonbare verbetering.
                  </p>
                </div>
              </div>

              <!-- Bestuur -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-olive/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-ink text-sm mb-1">Bestuur en toezicht</div>
                  <p class="text-ink-muted text-sm leading-relaxed">
                    Bestuurservaring bij onder andere de V&VN (Verpleegkundigen & Verzorgenden Nederland), VSB Máxima MC en STZ (Samenwerkende Topklinische Ziekenhuizen). In al deze rollen staat de versterking van professionele zeggenschap van verpleegkundigen centraal — de overtuiging dat verpleegkundigen een stevige en volwaardige stem verdienen in de inrichting van de zorg.
                  </p>
                </div>
              </div>

            </div>
          </div>

          <!-- Expertise -->
          <div class="reveal reveal-delay-2">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Expertise</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {expertise.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-muted">
                  <svg class="w-4 h-4 text-olive flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Visie -->
          <div class="reveal reveal-delay-3">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Mijn kijk op leren</h2>
            <div class="space-y-4 text-ink-muted leading-relaxed">
              <p>
                Leren is geen bijzaak in de zorg — het is een voorwaarde voor goede zorgverlening. Verpleegkundigen die blijven leren, leveren betere zorg. Organisaties die investeren in leren, bouwen aan duurzame kwaliteit.
              </p>
              <p>
                Maar leren werkt alleen als het aansluit bij de werkpraktijk. Een cursus die losstaat van de afdeling, een scholingsprogramma dat geen antwoord geeft op echte vragen — dat levert weinig op. Ik geloof in leren dat contextgevoelig is: afgestemd op de mensen, de omgeving en het moment.
              </p>
              <p>
                Mijn aanpak is altijd gericht op verbinding: tussen beleid en werkvloer, tussen kennis en gedrag, tussen ambitie en realiteit.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center">
      <div class="reveal max-w-xl mx-auto">
        <h2 class="font-serif text-2xl text-olive-dark mb-3">Nieuwsgierig of we een goede match zijn?</h2>
        <p class="text-ink-muted mb-7">Een eerste gesprek is altijd vrijblijvend. Ik hoor graag van u.</p>
        <Button href="/contact" variant="secondary" size="lg">Vrijblijvend kennismaken</Button>
      </div>
    </div>
  </section>

</BaseLayout>
