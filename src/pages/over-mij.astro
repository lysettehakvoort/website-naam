---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';

const expertise = [
  'Verpleegkundig leren en werkplekleren',
  'Ontwerp en evaluatie van scholingsprogramma\'s',
  'Leercultuur en leerklimaat in zorgorganisaties',
  'Kwaliteitsverbetering en professionele ontwikkeling',
  'Implementatie van verandering in complexe zorgomgevingen',
  'Projectleiding bij leer- en ontwikkelingsvraagstukken',
];
---

<BaseLayout
  title="Over Dr. Lysette Hakvoort — Van Inzicht naar Impact"
  description="Academicus en praktijkadviseur. Lysette Hakvoort combineert wetenschappelijk inzicht met jarenlange ervaring in verpleegkundig leren."
>

  <!-- Page hero -->
  <section class="bg-stone-50 border-b border-stone-100 py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl">
        <SectionHeading
          label="Over mij"
          title="Dr. Lysette Hakvoort"
          subtitle="Adviseur verpleegkundig leren & professionele ontwikkeling in de zorg"
        />
      </div>
    </div>
  </section>

  <!-- Introductie -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">

        <!-- Foto placeholder -->
        <div class="lg:col-span-2 reveal">
          <div class="rounded-3xl overflow-hidden border border-stone-100 relative max-w-sm mx-auto lg:mx-0">
            <img
              src="/foto-promotielysette.jpeg"
              alt="Dr. Lysette Hakvoort — Adviseur verpleegkundig leren"
              class="w-full h-auto object-cover"
            />
            <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-gradient-to-r from-olive via-olive-light to-copper"></div>
          </div>

          <!-- Contactinfo card -->
          <div class="mt-6 bg-white border border-stone-100 rounded-2xl p-5 max-w-sm mx-auto lg:mx-0">
            <div class="font-serif font-semibold text-olive-dark mb-1">Dr. Lysette Hakvoort</div>
            <div class="text-xs text-copper font-medium uppercase tracking-wider mb-4">Adviseur verpleegkundig leren</div>
            <div class="flex flex-col gap-2.5 text-sm text-ink-muted">
              <a href="mailto:vaninzichtnaarimpact@outlook.com" class="flex items-center gap-2 hover:text-olive transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                vaninzichtnaarimpact@outlook.com
              </a>
              <a href="tel:+31623922983" class="flex items-center gap-2 hover:text-olive transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                06-23922983
              </a>
              <a href="https://www.linkedin.com/in/lysette-hakvoort" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-olive transition-colors">
                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn profiel
              </a>
            </div>
          </div>
        </div>

        <!-- Tekst -->
        <div class="lg:col-span-3 flex flex-col gap-10">
          <!-- Introductie -->
          <div class="reveal">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Over mij</h2>
            <div class="space-y-4 text-ink-muted leading-relaxed">
              <p>
                Leren in de zorg fascineerde me al vroeg. Niet als theoretisch vraagstuk, maar als iets wat je ziet gebeuren — of juist niet — op de werkvloer. Wat maakt dat een verpleegkundige blijft leren, ook als de werkdruk hoog is? Wat helpt, en wat staat in de weg?
              </p>
              <p>
                Die vragen vormen de rode draad in mijn werk. Als adviseur help ik zorgorganisaties om eerlijke antwoorden te vinden op die vragen — en om op basis daarvan stappen te zetten die echt iets veranderen.
              </p>
              <p>
                Ik combineer een academische achtergrond in verpleegkunde en leren met jarenlange praktijkervaring in de zorgsector. Dat geeft me een blik die zowel analytisch als praktisch is: ik begrijp de theorie én de werkelijkheid van alledag in de zorg.
              </p>
            </div>
          </div>

          <!-- Expertise -->
          <div class="reveal reveal-delay-1">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Expertise</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {expertise.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-muted">
                  <svg class="w-4 h-4 text-olive flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Visie -->
          <div class="reveal reveal-delay-2">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Mijn kijk op leren</h2>
            <div class="space-y-4 text-ink-muted leading-relaxed">
              <p>
                Leren is geen bijzaak in de zorg — het is een voorwaarde voor goede zorgverlening. Verpleegkundigen die blijven leren, leveren betere zorg. Organisaties die investeren in leren, bouwen aan duurzame kwaliteit.
              </p>
              <p>
                Maar leren werkt alleen als het aansluit bij de werkpraktijk. Een cursus die losstaat van de afdeling, een scholingsprogramma dat geen antwoord geeft op echte vragen — dat levert weinig op. Ik geloof in leren dat contextgevoelig is: afgestemd op de mensen, de omgeving en het moment.
              </p>
              <p>
                Mijn aanpak is altijd gericht op verbinding: tussen beleid en werkvloer, tussen kennis en gedrag, tussen ambitie en realiteit.
              </p>
            </div>
          </div>

          <!-- Hoe ik werk -->
          <div class="reveal reveal-delay-3 bg-stone-50 rounded-2xl p-6 border border-stone-100">
            <h2 class="font-serif text-subheading text-olive-dark mb-4">Hoe ik werk</h2>
            <div class="space-y-3 text-ink-muted leading-relaxed">
              <p>
                Ik begin met luisteren. Niet met een standaardvragenlijst, maar met echte aandacht voor uw situatie. Pas als ik begrijp wat er speelt, maak ik een analyse en kom ik met een voorstel.
              </p>
              <p>
                Ik werk direct en open. U weet waar u aan toe bent — ook als mijn bevindingen niet altijd zijn wat u verwachtte. Juist dan is eerlijk advies het meest waardevol.
              </p>
              <p class="font-medium text-ink">
                Samenwerken met mij betekent: één aanspreekpunt, persoonlijke betrokkenheid en een adviseur die uw organisatie kent.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center">
      <div class="reveal max-w-xl mx-auto">
        <h2 class="font-serif text-2xl text-olive-dark mb-3">Nieuwsgierig of we een goede match zijn?</h2>
        <p class="text-ink-muted mb-7">Een eerste gesprek is altijd vrijblijvend. Ik hoor graag van u.</p>
        <Button href="/contact" variant="secondary" size="lg">Samenwerken? Plan een gesprek</Button>
      </div>
    </div>
  </section>

</BaseLayout>
