---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Pagina niet gevonden — Van Inzicht naar Impact"
  description="De pagina die u zoekt bestaat niet of is verplaatst."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center py-24">
    <div class="text-center max-w-lg mx-auto px-6">
      <div class="font-serif text-8xl font-bold text-olive/20 mb-4">404</div>
      <h1 class="font-serif text-2xl text-olive-dark mb-4">Pagina niet gevonden</h1>
      <p class="text-ink-muted mb-8 leading-relaxed">
        De pagina die u zoekt bestaat niet of is verplaatst. Ga terug naar de homepage of neem contact op.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button href="/" variant="primary">Terug naar home</Button>
        <Button href="/contact" variant="outline">Contact</Button>
      </div>
    </div>
  </section>
</BaseLayout>
