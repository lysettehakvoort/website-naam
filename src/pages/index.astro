---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ExpertiseCard from '../components/ExpertiseCard.astro';

const expertise = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
    title: 'Inzicht in de verpleegkundige praktijk',
    description: 'Ik maak zichtbaar wat professionele ontwikkeling belemmert en wat nodig is om leren en ontwikkelen echt te laten werken in de praktijk.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>',
    title: 'Leren en ontwikkelen met impact',
    description: 'Ik help organisaties en bedrijven om hun impact na leer- en ontwikkeltrajecten inzichtelijk te maken.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg>',
    title: 'Van strategie naar praktijk',
    description: 'Ik verbind beleid en praktijk en zorg dat strategische ambities rond professionele ontwikkeling daadwerkelijk landen op de verpleegkundige werkvloer.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"/></svg>',
    title: 'Onderzoek en ontwikkeling in de verpleegkundige praktijk',
    description: 'Als onderzoeker werk ik aan vraagstukken rond het versterken van verpleegkundig onderzoek en vertaal ik inzichten naar toepasbare verbeteringen. Datagedreven en praktijkgericht.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>',
    title: 'Duurzame professionele ontwikkeling',
    description: 'Ik werk aan duurzame verankering van professionele ontwikkeling, zodat investeren in professionele ontwikkeling van verpleegkundigen blijft bijdragen aan de zorgtransformatie.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/></svg>',
    title: 'Bestuur en toezicht in de zorg',
    description: 'Als bestuurder en toezichthouder breng ik brede ervaring mee naar de bestuurstafel; praktijkgericht, analytisch, onderzoekend en strategisch.',
  },
];

const onderscheidend = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>',
    title: 'Academisch én praktisch',
    description: 'Met een doctoraat in de verplegingswetenschappen combineer ik wetenschappelijk inzicht met jarenlange praktijkervaring in de zorg. Geen theorie zonder toepassing.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>',
    title: 'Direct en persoonlijk',
    description: 'Als eenmanszaak heeft u rechtstreeks contact met mij. U werkt met één adviseur die betrokken is van begin tot eind.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>',
    title: 'Van analyse naar actie',
    description: 'Ik lever geen rapporten die in een la verdwijnen. Mijn adviezen zijn concreet, uitvoerbaar en gericht op echte verandering in de dagelijkse zorgpraktijk.',
  },
];
---

<BaseLayout
  title="Van Inzicht naar Impact — Adviseur verpleegkundig leren"
  description="Lysette Hakvoort adviseert zorgorganisaties over leren, scholing en professionele ontwikkeling van verpleegkundigen."
>

  <!-- ===== HERO ===== -->
  <section class="relative bg-gradient-to-br from-olive-dark via-olive to-olive/80 text-white overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full bg-olive-light -translate-y-1/2 translate-x-1/4 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-copper -translate-y-1/4 -translate-x-1/4 blur-3xl"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center">

        <!-- Tekst links -->
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-olive-light animate-pulse" aria-hidden="true"></span>
            <span class="text-sm text-white/90">Dr. Lysette Hakvoort · Senior adviseur, onderzoeker en bestuurder in de zorg</span>
          </div>

          <h1 class="font-serif text-display font-bold text-white mb-6 leading-tight">
            van Inzicht naar Impact<br class="hidden sm:block" />
            <span class="text-olive-light">in de zorg</span>
          </h1>

          <p class="text-lg text-white/80 leading-relaxed mb-10 max-w-2xl">
            Ik maak zichtbaar wat de professionele ontwikkeling van verpleegkundigen belemmert — en zet dat om naar een aanpak die beklijft. Praktijkgericht, onderbouwd en afgestemd op uw organisatie.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="/diensten"
              class="inline-flex items-center gap-2 bg-white text-olive-dark font-semibold px-7 py-3.5 rounded-lg hover:bg-stone-50 transition-all duration-200 shadow-lg hover:shadow-xl"
            >
              Bekijk mijn diensten
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 bg-transparent border-2 border-white/60 text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-white/10 hover:border-white transition-all duration-200"
            >
              Vrijblijvend kennismaken
            </a>
          </div>
        </div>

        <!-- Foto rechts -->
        <div class="hidden lg:flex lg:col-span-2 justify-center lg:justify-end">
          <div class="relative w-56 xl:w-64">
            <div class="rounded-3xl overflow-hidden shadow-2xl">
              <img
                src="/foto-profiellysette.jpeg"
                alt="Dr. Lysette Hakvoort"
                class="w-full h-auto object-cover mix-blend-multiply"
              />
            </div>
            <!-- Decoratief kader -->
            <div class="absolute -bottom-3 -right-3 w-full h-full rounded-3xl border-2 border-olive-light/30 -z-10"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- Wave divider -->
    <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block">
        <path d="M0 60L60 50C120 40 240 20 360 15C480 10 600 20 720 27.5C840 35 960 40 1080 37.5C1200 35 1320 25 1380 20L1440 15V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ===== KERNBOODSCHAP ===== -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <SectionHeading
            label="Waar ik voor sta"
            title="Verpleegkundigen zijn de motor van de zorgtransformatie. Duurzame verankering van professionele ontwikkeling is een voorwaarde om die motor aan te zwengelen."
          />
        </div>
        <div class="reveal reveal-delay-2 space-y-4 text-ink-muted leading-relaxed">
          <p>
            Verpleegkundigen zijn de grootste beroepsgroep in de zorg, staan het dichtst bij de patiënt en hebben dagelijks directe invloed op de kwaliteit van zorg. Die positie biedt enorm potentieel — maar dan moet professionele ontwikkeling wel duurzaam verankerd zijn in de praktijk.
          </p>
          <p>
            Ik maak zichtbaar wat de professionele ontwikkeling van verpleegkundigen belemmert en help organisaties dit om te zetten naar een aanpak die wél werkt — onderbouwd, praktisch en afgestemd op de dagelijkse praktijk.
          </p>
          <p>
            Met mijn brede ervaring verbind ik strategie en werkvloer en werk ik aan ontwikkeling die beklijft, zodat leren niet stopt bij inzicht, maar leidt tot blijvende impact in de verpleegkundige praktijk.
          </p>
          <div class="pt-2">
            <a href="/over-mij" class="inline-flex items-center gap-2 text-olive font-medium hover:text-olive-dark transition-colors">
              Lees meer over mij
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EXPERTISEGEBIEDEN ===== -->
  <section class="relative py-20 lg:py-28 bg-stone-50 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-14">
        <SectionHeading
          label="Expertisegebieden"
          title="Waar ik u mee help"
          subtitle="Als verpleegkundige (BIG geregistreerd), senior adviseur, onderzoeker en bestuurder verbind ik praktijk, strategie en onderzoek. Dankzij deze brede ervaring werk ik aan vraagstukken die de professionele ontwikkeling van verpleegkundigen duurzaam versterken."
          align="center"
        />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {expertise.map((item, i) => (
          <ExpertiseCard
            title={item.title}
            description={item.description}
            icon={item.icon}
            delay={Math.min(i + 1, 5) as 1 | 2 | 3 | 4 | 5}
          />
        ))}
      </div>
      <div class="text-center mt-10 reveal">
        <Button href="/diensten" variant="primary">Bekijk alle diensten</Button>
      </div>
    </div>
    <!-- Golf naar wit -->
    <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block">
        <path d="M0 60L60 50C120 40 240 20 360 15C480 10 600 20 720 27.5C840 35 960 40 1080 37.5C1200 35 1320 25 1380 20L1440 15V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ===== WERKWIJZE PREVIEW ===== -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal">
          <SectionHeading
            label="Werkwijze"
            title="Hoe we samenwerken"
            subtitle="Een samenwerking begint met het scherp krijgen van wat er werkelijk speelt. Van eerste analyse tot duurzame borging werk ik stap voor stap; doordacht, betrokken en gericht op duurzame verandering met impact in de praktijk."
          />
          <div class="mt-8">
            <Button href="/werkwijze" variant="outline">Lees meer over mijn werkwijze</Button>
          </div>
        </div>

        <!-- Van Inzicht naar Impact figuur -->
        <div class="reveal reveal-delay-1 flex flex-col items-center justify-center py-4">

          <!-- Inzicht -->
          <div class="w-full flex flex-col items-center">
            <div class="bg-olive-dark text-white rounded-2xl px-6 py-4 text-center w-full max-w-xs shadow-md">
              <div class="flex justify-center mb-1" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div class="font-serif font-semibold text-lg">Inzicht</div>
              <div class="text-white/70 text-xs mt-1">Zichtbaar maken wat er werkelijk speelt</div>
            </div>
          </div>

          <!-- Pijl -->
          <div class="flex flex-col items-center my-2">
            <div class="w-px h-6 bg-olive/30"></div>
            <svg class="w-5 h-5 text-olive" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </div>

          <!-- Analyse & Strategie -->
          <div class="w-full grid grid-cols-2 gap-3 max-w-xs">
            <div class="bg-white border border-olive/20 rounded-xl px-4 py-3 text-center shadow-sm">
              <div class="flex justify-center mb-1" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
              </div>
              <div class="font-semibold text-olive-dark text-sm">Analyse</div>
              <div class="text-ink-muted text-xs mt-0.5">Begrijpen wat er speelt</div>
            </div>
            <div class="bg-white border border-olive/20 rounded-xl px-4 py-3 text-center shadow-sm">
              <div class="flex justify-center mb-1" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg>
              </div>
              <div class="font-semibold text-olive-dark text-sm">Strategie</div>
              <div class="text-ink-muted text-xs mt-0.5">Richting en aanpak</div>
            </div>
          </div>

          <!-- Pijl -->
          <div class="flex flex-col items-center my-2">
            <div class="w-px h-6 bg-olive/30"></div>
            <svg class="w-5 h-5 text-olive" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </div>

          <!-- Implementatie & Borging -->
          <div class="w-full grid grid-cols-2 gap-3 max-w-xs">
            <div class="bg-white border border-copper/20 rounded-xl px-4 py-3 text-center shadow-sm">
              <div class="flex justify-center mb-1" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-copper" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/></svg>
              </div>
              <div class="font-semibold text-copper-dark text-sm">Implementatie</div>
              <div class="text-ink-muted text-xs mt-0.5">Samen aan de slag</div>
            </div>
            <div class="bg-white border border-copper/20 rounded-xl px-4 py-3 text-center shadow-sm">
              <div class="flex justify-center mb-1" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-copper" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              </div>
              <div class="font-semibold text-copper-dark text-sm">Borging</div>
              <div class="text-ink-muted text-xs mt-0.5">Duurzaam verankerd</div>
            </div>
          </div>

          <!-- Pijl -->
          <div class="flex flex-col items-center my-2">
            <div class="w-px h-6 bg-copper/30"></div>
            <svg class="w-5 h-5 text-copper" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </div>

          <!-- Impact -->
          <div class="w-full flex flex-col items-center">
            <div class="bg-gradient-to-r from-copper to-copper-dark text-white rounded-2xl px-6 py-4 text-center w-full max-w-xs shadow-md">
              <div class="flex justify-center mb-1" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/></svg>
              </div>
              <div class="font-serif font-semibold text-lg">Impact</div>
              <div class="text-white/70 text-xs mt-1">Blijvende verandering in de praktijk</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ===== WAAROM SAMENWERKEN ===== -->
  <section class="relative py-20 lg:py-28 bg-stone-50 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-14">
        <SectionHeading
          label="Waarom samenwerken"
          title="Wat u van mij kunt verwachten"
          align="center"
        />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {onderscheidend.map((item, i) => (
          <div class={`reveal reveal-delay-${i + 1} text-center px-4`}>
            <div class="w-16 h-16 rounded-2xl bg-white shadow-sm border border-stone-100 flex items-center justify-center mx-auto mb-5">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-serif font-semibold text-olive-dark text-xl mb-3">{item.title}</h3>
            <p class="text-ink-muted leading-relaxed text-sm">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
    <!-- Golf naar wit -->
    <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block">
        <path d="M0 60L60 50C120 40 240 20 360 15C480 10 600 20 720 27.5C840 35 960 40 1080 37.5C1200 35 1320 25 1380 20L1440 15V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ===== CTA BLOK ===== -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="reveal bg-gradient-to-br from-olive-dark to-olive rounded-3xl px-8 py-16 lg:px-16 text-center text-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" aria-hidden="true">
          <div class="absolute top-0 right-0 w-64 h-64 rounded-full bg-olive-light blur-3xl"></div>
          <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full bg-copper blur-3xl"></div>
        </div>
        <div class="relative">
          <h2 class="font-serif text-heading text-white mb-4">Klaar om het gesprek aan te gaan?</h2>
          <p class="text-white/80 max-w-xl mx-auto mb-8 leading-relaxed">
            Heeft uw organisatie een vraagstuk op het gebied van professionele ontwikkeling van verpleegkundigen? Ik denk graag met u mee, vrijblijvend en gericht.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-copper hover:bg-copper-dark text-white font-semibold px-8 py-4 rounded-lg transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            Neem contact op
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
