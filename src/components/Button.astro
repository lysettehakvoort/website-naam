---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
} = Astro.props;

const base = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2';

const variants = {
  primary: 'bg-olive hover:bg-olive-dark text-white shadow-sm hover:shadow-md focus-visible:ring-olive',
  secondary: 'bg-copper hover:bg-copper-dark text-white shadow-sm hover:shadow-md focus-visible:ring-copper',
  outline: 'border-2 border-olive text-olive hover:bg-olive hover:text-white focus-visible:ring-olive',
};

const sizes = {
  sm: 'text-sm px-4 py-2',
  md: 'text-sm px-6 py-3',
  lg: 'text-base px-8 py-4',
};

const classes = [base, variants[variant], sizes[size], className].join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
