---
interface Props {
  title: string;
  challenge: string;
  approach: string;
  result: string;
  icon: string;
  delay?: number;
}

const { title, challenge, approach, result, icon, delay = 0 } = Astro.props;
---

<article class={`reveal reveal-delay-${delay} bg-white rounded-2xl border border-stone-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1`}>
  <div class="bg-gradient-to-br from-stone-50 to-white p-6 border-b border-stone-100">
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 rounded-xl bg-olive/10 flex items-center justify-center flex-shrink-0">
        <span class="text-2xl" aria-hidden="true">{icon}</span>
      </div>
      <h3 class="font-serif font-semibold text-olive-dark text-xl pt-1">{title}</h3>
    </div>
  </div>

  <div class="p-6 flex flex-col gap-5">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="w-2 h-2 rounded-full bg-copper flex-shrink-0" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-copper uppercase tracking-wider">De uitdaging</span>
      </div>
      <p class="text-ink-muted text-sm leading-relaxed">{challenge}</p>
    </div>

    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="w-2 h-2 rounded-full bg-olive flex-shrink-0" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-olive uppercase tracking-wider">De aanpak</span>
      </div>
      <p class="text-ink-muted text-sm leading-relaxed">{approach}</p>
    </div>

    <div class="bg-olive/5 rounded-xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-2 h-2 rounded-full bg-olive-light flex-shrink-0" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-olive uppercase tracking-wider">Het resultaat</span>
      </div>
      <p class="text-ink text-sm leading-relaxed font-medium">{result}</p>
    </div>
  </div>
</article>
