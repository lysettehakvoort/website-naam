---
const year = new Date().getFullYear();
---

<footer class="bg-olive-dark text-white/80">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Kolom 1: Over -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-md bg-olive flex items-center justify-center flex-shrink-0">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" aria-hidden="true">
              <path d="M6 18 L12 6 L18 18" stroke="#A8C068" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M8.5 13.5 L15.5 13.5" stroke="#B5743A" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-serif font-semibold text-white text-sm">van Inzicht naar Impact</span>
        </div>
        <p class="text-sm leading-relaxed text-white/70">
          Adviseur professionele ontwikkeling van verpleegkundigen. Verbindt praktijk, onderzoek en strategie.
        </p>
      </div>

      <!-- Kolom 2: Navigatie -->
      <div>
        <h3 class="font-semibold text-white text-sm uppercase tracking-wider mb-4">Navigatie</h3>
        <ul class="flex flex-col gap-2.5">
          {[
            { href: '/', label: 'Home' },
            { href: '/diensten', label: 'Diensten' },
            { href: '/werkwijze', label: 'Werkwijze' },
            { href: '/over-mij', label: 'Over mij' },
            { href: '/contact', label: 'Contact' },
          ].map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kolom 3: Contact -->
      <div>
        <h3 class="font-semibold text-white text-sm uppercase tracking-wider mb-4">Contact</h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href="mailto:vaninzichtnaarimpact@outlook.com"
              class="text-sm hover:text-white transition-colors flex items-start gap-2"
            >
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-olive-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              vaninzichtnaarimpact@outlook.com
            </a>
          </li>
          <li>
            <a
              href="tel:+31623922983"
              class="text-sm hover:text-white transition-colors flex items-start gap-2"
            >
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-olive-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              06-23922983
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/dr-lysette-hakvoort-92666b71/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm hover:text-white transition-colors flex items-start gap-2"
            >
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-olive-light" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-white/50">
      <p>© {year} van Inzicht naar Impact — Dr. Lysette Hakvoort</p>
      <a href="/privacyverklaring" class="hover:text-white/80 transition-colors">Privacyverklaring</a>
    </div>
  </div>
</footer>
